# ── Required ────────────────────────────────────────────────────────────────────

# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Anthropic API key from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Quidli Connect API key from https://connect.quid.li
# Required for /scores and /drop. Also covers /lookup (no per-request cost).
QUIDLI_API_KEY=your_quidli_api_key_here

# ── x402 Pay-per-request (alternative to QUIDLI_API_KEY for /lookup) ───────────
# A wallet funded with USDC + ETH on Base. The bot pays automatically on 402 responses.
# Not needed if QUIDLI_API_KEY is set.
BOT_WALLET_PRIVATE_KEY=
BOT_WALLET_ADDRESS=

# ── Optional ────────────────────────────────────────────────────────────────────

# Claude model to use. Defaults to claude-sonnet-4-6
CLAUDE_MODEL=claude-sonnet-4-6

# Override the bot's default personality/instructions
SYSTEM_PROMPT=

# Comma-separated Discord channel IDs where the bot responds to ALL messages.
# If empty, the bot only responds when @mentioned.
DISCORD_ACTIVE_CHANNELS=

# Comma-separated Discord user IDs allowed to use the bot.
# If empty, anyone can use it.
DISCORD_ALLOWED_USERS=

# Comma-separated Discord role names allowed to use the bot.
# If empty, anyone can use it. Example: Team Quidli,Admins
DISCORD_ALLOWED_ROLES=

# Your Discord user ID — drops from your account use the host QUIDLI_API_KEY automatically.
# Find your ID: Discord Settings → Advanced → Enable Developer Mode → right-click yourself → Copy User ID
BOT_OWNER_ID=

# ── Per-user key encryption ───────────────────────────────────────────────────

# 32-byte hex key used to AES-256-GCM encrypt stored user API keys.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, keys are stored in plaintext (not recommended for production).
MASTER_ENCRYPTION_KEY=

# ── Web search (required for conditional drops) ───────────────────────────────

# Brave Search API key from https://brave.com/search/api
BRAVE_SEARCH_API_KEY=

# ── Multi-LLM provider switching ─────────────────────────────────────────────

# Default LLM provider: anthropic (recommended), gemini, openai, or minds
DEFAULT_LLM_PROVIDER=anthropic

# Gemini — from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI — from https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Minds (Animoca Brands) — uses @animocabrands/minds-client-lib, no CLI install needed
# Users register their own Builder API key by DMing the bot: !minds <key>
# No shared credentials needed here — Minds is fully per-user.
